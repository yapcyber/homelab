# =============================================================================
# .env.example — Variables globales du Homelab yapserver.fr
# =============================================================================
# INSTRUCTIONS :
#   1. Copier ce fichier : cp .env.example .env
#   2. Remplir TOUTES les valeurs (remplacer les CHANGEME)
#   3. Ne JAMAIS committer le fichier .env — il est dans le .gitignore
#   4. Pour partager des secrets, utiliser SOPS : sops --encrypt .env > .enc.env
# =============================================================================

# -----------------------------------------------------------------------------
# Domaine et DNS
# -----------------------------------------------------------------------------
DOMAIN=yapserver.fr
INT_DOMAIN=int.yapserver.fr

# -----------------------------------------------------------------------------
# Timezone et utilisateur système
# -----------------------------------------------------------------------------
TZ=Europe/Paris
PUID=1000
PGID=1000

# -----------------------------------------------------------------------------
# Cloudflare (pour ACME DNS Challenge et Tunnels)
# -----------------------------------------------------------------------------
CF_API_EMAIL=CHANGEME@email.fr
CF_DNS_API_TOKEN=CHANGEME

# L'auth du dashboard Traefik vit dans le fichier gitignoré
# services/infra/traefik/dynamic/secrets/traefik_users.

# -----------------------------------------------------------------------------
# Authentik (IdP / SSO)
# -----------------------------------------------------------------------------
# Générer avec : openssl rand 60 | base64 -w 0
AUTHENTIK_SECRET_KEY=CHANGEME
AUTHENTIK_POSTGRES_DB=authentik
AUTHENTIK_POSTGRES_USER=authentik
AUTHENTIK_POSTGRES_PASSWORD=CHANGEME

# -----------------------------------------------------------------------------
# Bases de données (partagées entre services)
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=CHANGEME
REDIS_PASSWORD=CHANGEME

# -----------------------------------------------------------------------------
# Adresses réseau (alignées avec les VLANs)
# -----------------------------------------------------------------------------
MGMT_SUBNET=10.0.10.0/24
PROD_SUBNET=10.0.30.0/24
DMZ_SUBNET=10.0.40.0/24
SOC_SUBNET=10.0.50.0/24
STORAGE_SUBNET=10.0.60.0/24

# IP du NAS (VLAN 60)
NAS_IP=10.0.60.10

# IP Wazuh Manager (VLAN 50)
WAZUH_MANAGER_IP=10.0.30.14

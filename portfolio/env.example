# =============================================================================
# portfolio/.env.example
# Portfolio Docusaurus + Cloudflare Tunnel
# =============================================================================

DOMAIN=yapserver.fr
TZ=Europe/Paris

# =============================================================================
# CLOUDFLARE TUNNEL TOKEN
# =============================================================================
# Procédure d'obtention (Phase 4) :
#
#   1. https://dash.cloudflare.com → Zero Trust → Networks → Tunnels
#   2. "Create a tunnel" → Cloudflared → Name: "homelab-tunnel"
#   3. Copier le token affiché (commence par eyJ...)
#   4. Configurer le "Public Hostname" (tunnel portfolio-homelab) :
#
#      Hostname                | Service
#      ------------------------+--------------------------------
#      portfolio.yapserver.fr  | http://portfolio:80
#
#      Note : cloudflared tourne dans la même compose que nginx (réseau dmz)
#             et joint directement le container "portfolio" sur le port 80.
#             Aucun Traefik, aucun accès au VLAN 30.
#
# Ce token permet à cloudflared de s'authentifier auprès de Cloudflare.
# Le traiter comme un secret (ne pas committer en clair).
CLOUDFLARE_TUNNEL_TOKEN=CHANGEME

# =============================================================================
# PUBLICATION DU PORTFOLIO — WORKFLOW HEBDOMADAIRE
# =============================================================================
# 1. Écrire un article dans blog/YYYY-MM-DD-titre.md
# 2. Tester en local : npm start (http://localhost:3000)
# 3. Build de vérification : npm run build
# 4. Committer et pousser sur GitHub (repo public)
# 5. En Phase 4 : le container portfolio se rebuild automatiquement
#    (ou manuellement : docker compose up -d --build portfolio)
# 6. Poster le lien sur LinkedIn avec un extrait de l'article
#
# STRUCTURE D'UN POST LINKEDIN EFFICACE :
#   - Titre accrocheur + emoji
#   - 3-5 lignes de contexte (pourquoi cette phase / ce problème ?)
#   - Le problème rencontré et la solution trouvée
#   - Screenshot ou diagram
#   - Lien vers l'article complet sur yapserver.fr
#   - Hashtags : #homelab #devops #cybersecurity #linux #networking
# =============================================================================

# Dawarich — copier vers .env et remplacer les valeurs.
POSTGRES_USER=dawarich
POSTGRES_PASSWORD=CHANGE_ME        # openssl rand -hex 24
POSTGRES_DB=dawarich
SECRET_KEY_BASE=CHANGE_ME          # openssl rand -hex 64

# SSO Authentik (provider OIDC "dawarich")
OIDC_CLIENT_ID=CHANGE_ME
OIDC_CLIENT_SECRET=CHANGE_ME
OIDC_ISSUER=https://auth.yapserver.fr/application/o/dawarich
OIDC_REDIRECT_URI=https://dawarich.yapserver.fr/users/auth/openid_connect/callback
OIDC_PROVIDER_NAME=Authentik

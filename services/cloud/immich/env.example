# =============================================================================
# services/cloud/immich/.env.example
# Immich — Gestion photos/vidéos
# =============================================================================
#
# ⚠️  IMMICH CHANGE VITE — Toujours vérifier avant de mettre à jour :
#   https://github.com/immich-app/immich/releases
#   La version IMMICH_VERSION et IMMICH_POSTGRES_TAG doivent être compatibles.
#   Le CHANGELOG indique explicitement si une migration de base de données
#   est nécessaire (toujours lire avant docker compose pull && up -d).
# =============================================================================

# =============================================================================
# VERSIONS — Les deux doivent être compatibles entre elles
# =============================================================================
# Version Immich — https://github.com/immich-app/immich/releases
IMMICH_VERSION=v1.118.2

# Version PostgreSQL + pgvecto-rs — compatibilité vérifiée dans le CHANGELOG Immich
# Format : pg16-v0.X.Y (la version pgvecto doit correspondre à la version Immich)
IMMICH_POSTGRES_TAG=pg16-v0.3.0

DOMAIN=yapserver.fr
TZ=Europe/Paris

# =============================================================================
# STOCKAGE DES PHOTOS
# =============================================================================
# Chemin ABSOLU sur la VM hôte où les photos originales sont stockées.
# Ce dossier est monté dans le container comme /usr/src/app/upload.
#
# Phase 4 — remplacer par un mount NFS vers le NAS (VLAN 60) :
#   IMMICH_UPLOAD_LOCATION=/mnt/nas-immich
#   (après avoir configuré le mount NFS dans /etc/fstab de la VM)
IMMICH_UPLOAD_LOCATION=./data/uploads

# =============================================================================
# BASE DE DONNÉES PostgreSQL + pgvecto.rs
# =============================================================================
IMMICH_DB_NAME=immich
IMMICH_DB_USER=immich
# Générer : openssl rand 32 | base64 -w 0
IMMICH_DB_PASSWORD=CHANGEME

# =============================================================================
# REDIS
# =============================================================================
# Générer : openssl rand 24 | base64 -w 0
IMMICH_REDIS_PASSWORD=CHANGEME

# =============================================================================
# CONFIGURATION INITIALE (Phase 4 — via l'interface web)
# =============================================================================
# 1. Créer le compte admin sur https://immich.yapserver.fr (premier accès)
# 2. Administration → Users → créer les comptes famille
# 3. Administration → Machine Learning → activer/configurer les modèles IA
# 4. Administration → Storage Template → organiser le stockage par date/personne
#    Exemple de template : {{y}}/{{MMMM}}/{{filename}}
#    → 2024/Juillet/IMG_1234.jpg
# 5. App mobile (iOS/Android) → ajouter le serveur : https://immich.yapserver.fr
#    → activer la sauvegarde automatique en WiFi
#
# PARTAGE FAMILIAL :
#   Immich supporte les albums partagés et les liens de partage temporaires.
#   Chaque membre de la famille a son propre espace, peut partager des albums.
#   Pas besoin d'Authentik par-dessus — Immich gère les utilisateurs nativement.
# =============================================================================

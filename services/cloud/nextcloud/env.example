# =============================================================================
# services/cloud/nextcloud/.env.example
# =============================================================================

# Version — https://hub.docker.com/_/nextcloud (choisir tag stable, ex: 30-apache)
NEXTCLOUD_TAG=30-apache

DOMAIN=yapserver.fr
TZ=Europe/Paris

# =============================================================================
# POSTGRESQL
# =============================================================================
NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud
# Générer : openssl rand 32 | base64 -w 0
NEXTCLOUD_DB_PASSWORD=CHANGEME

# =============================================================================
# REDIS
# =============================================================================
# Générer : openssl rand 24 | base64 -w 0
NEXTCLOUD_REDIS_PASSWORD=CHANGEME

# =============================================================================
# COMPTE ADMIN INITIAL
# =============================================================================
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGEME

# =============================================================================
# EMAIL / SMTP (optionnel)
# =============================================================================
NEXTCLOUD_SMTP_HOST=
NEXTCLOUD_SMTP_SECURE=tls
NEXTCLOUD_SMTP_PORT=587
NEXTCLOUD_SMTP_USER=
NEXTCLOUD_SMTP_PASSWORD=
NEXTCLOUD_MAIL_FROM=nextcloud

# =============================================================================
# APPS À INSTALLER APRÈS LE PREMIER DÉMARRAGE (Phase 4)
# =============================================================================
# Via l'interface Admin → Applications, ou via CLI :
#   docker exec -u www-data nextcloud php occ app:install <app>
#
# Recommandées pour ce homelab :
#   - calendar         → synchronisation agenda (CalDAV)
#   - contacts         → synchronisation contacts (CardDAV)
#   - notes            → alternative simple à AnyType pour les notes
#   - tasks            → gestion de tâches (compatible CalDAV)
#   - deck             → Kanban (équivalent Trello)
#   - memories         → alternative à Immich pour les photos (si Immich trop lourd)
#   - previewgenerator → génère les miniatures en avance (performances)
#   - admin_audit      → audit log pour Wazuh (Phase 5)
# =============================================================================

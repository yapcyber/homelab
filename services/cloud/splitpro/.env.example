# SplitPro — copier vers .env et remplacer les valeurs.

POSTGRES_USER=splitpro
POSTGRES_PASSWORD=CHANGE_ME    # openssl rand -hex 24
POSTGRES_DB=splitpro
# NB : écrire l'URL complète (pas de ${VAR} — non interpolé par env_file)
DATABASE_URL=postgresql://splitpro:CHANGE_ME@splitpro-db:5432/splitpro

NEXTAUTH_SECRET=CHANGE_ME      # openssl rand -base64 32
NEXTAUTH_URL=https://split.yapserver.fr
DEFAULT_HOMEPAGE=/balances

# Pas de SMTP → signup email désactivé ; utiliser Authentik (OIDC).
DISABLE_EMAIL_SIGNUP=true
ENABLE_SENDING_INVITES=false

# --- Authentik (SSO) ---
# Créer un provider OAuth2/OIDC "splitpro" dans Authentik
# (redirect URI : https://split.yapserver.fr/api/auth/callback/authentik)
# puis renseigner :
#AUTHENTIK_ID=
#AUTHENTIK_SECRET=
#AUTHENTIK_ISSUER=https://auth.yapserver.fr/application/o/splitpro

CURRENCY_RATE_PROVIDER=frankfurter

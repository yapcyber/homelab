# =============================================================================
# services/cv-pipeline/.env.example
# Variables d'environnement — CV Pipeline
# =============================================================================

DOMAIN=yapserver.fr
TZ=Europe/Paris

# =============================================================================
# IMAP — Boîte mail dédiée aux alertes d'offres
# =============================================================================
# Créer une adresse dédiée (ex: offres-alternance@gmail.com)
# Gmail : activer IMAP + mot de passe d'application (pas le mot de passe principal)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=offres-alternance@gmail.com
IMAP_PASS=CHANGEME_MOT_DE_PASSE_APPLICATION
IMAP_FOLDER=INBOX
IMAP_CHECK_INTERVAL=300  # Vérification toutes les 5 minutes

# =============================================================================
# FILTRAGE GÉOGRAPHIQUE — OpenRouteService (gratuit, sans CB)
# =============================================================================
# Créer un compte sur https://openrouteservice.org/ → API Key gratuite
ORS_API_KEY=CHANGEME
HOME_ADDRESS=Lille, France
MAX_COMMUTE_MINUTES=60

# =============================================================================
# INTELLIGENCE ARTIFICIELLE — Claude API (anti-hallucination)
# =============================================================================
# Créer une clé sur https://console.anthropic.com/
# Coût estimé : ~0.01€ par adaptation de CV (très faible)
ANTHROPIC_API_KEY=CHANGEME
AI_MODEL=claude-sonnet-4-20250514

# =============================================================================
# GIT — Repo du CV
# =============================================================================
# Repo GitHub contenant le Master CV en Markdown
# Format SSH recommandé (clé SSH montée dans le container)
GIT_REPO_URL=git@github.com:yapcyber/cv.git
GIT_USERNAME=yapcyber
GIT_EMAIL=ton-email@example.com
# Chemin vers la clé SSH sur le HOST (sera montée en read-only dans le container)
SSH_KEY_PATH=~/.ssh/id_ed25519_cv

# =============================================================================
# SMTP — Notifications email
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=offres-alternance@gmail.com
SMTP_PASS=CHANGEME
NOTIFY_EMAIL=ton-email-perso@example.com

# =============================================================================
# services/privacy/.env.example
# Variables d'environnement — Stack Privacy
# =============================================================================

# HaveIBeenPwned API (gratuit pour usage personnel)
# https://haveibeenpwned.com/API/Key
HIBP_API_KEY=CHANGEME

# Fréquence des scans Maigret (heures)
MAIGRET_SCAN_INTERVAL=24

# Fréquence de vérification des breaches (heures)
BREACH_CHECK_INTERVAL=12

# Opt-out engine — mettre à true pour envoyer réellement les emails
# Laisser à true en mode test pour vérifier les emails générés sans les envoyer
OPT_OUT_DRY_RUN=true

# Ghostfolio — copier vers .env et remplacer les valeurs.
# Générer les secrets : openssl rand -hex 32

# CACHE
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# POSTGRES
POSTGRES_DB=ghostfolio-db
POSTGRES_USER=ghostfolio
POSTGRES_PASSWORD=CHANGE_ME

# VARIOUS
ACCESS_TOKEN_SALT=CHANGE_ME
JWT_SECRET_KEY=CHANGE_ME
# NB : écrire l'URL complète (pas de ${VAR} — non interpolé par env_file)
DATABASE_URL=postgresql://ghostfolio:CHANGE_ME@postgres:5432/ghostfolio-db?connect_timeout=300

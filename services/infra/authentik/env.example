# =============================================================================
# services/infra/authentik/.env.example
# Stack Authentik IdP / SSO
# =============================================================================
# INSTRUCTIONS :
#   1. cp .env.example .env
#   2. Remplir TOUTES les valeurs CHANGEME
#   3. Ne jamais committer .env
#   4. Chiffrer avec SOPS si le repo est public : sops --encrypt .env > .enc.env
# =============================================================================

# Domaine principal
DOMAIN=yapserver.fr

# =============================================================================
# VERSION AUTHENTIK
# =============================================================================
# Vérifier la dernière version stable sur :
#   https://github.com/goauthentik/authentik/releases
# Format : YYYY.M.patch (ex: 2024.12.3)
# NE PAS utiliser "latest" en prod — toujours pinner la version.
# Procédure de mise à jour :
#   1. Changer la version ici
#   2. docker compose pull
#   3. docker compose up -d
#   Authentik gère les migrations de base de données automatiquement.
# =============================================================================
AUTHENTIK_TAG=2026.5.3

# =============================================================================
# CLÉ SECRÈTE — CRITIQUE
# =============================================================================
# Générer avec : openssl rand 60 | base64 -w 0
# ATTENTION : Ne JAMAIS changer cette clé après le premier démarrage.
# Un changement invalide toutes les sessions actives et tous les tokens
# (OIDC, API, invitations). Les utilisateurs seront déconnectés de force.
# Sauvegarder cette clé dans un gestionnaire de mots de passe.
# =============================================================================
AUTHENTIK_SECRET_KEY=CHANGEME

# =============================================================================
# POSTGRESQL
# =============================================================================
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_POSTGRESQL__NAME=authentik
# Générer avec : openssl rand 32 | base64 -w 0
AUTHENTIK_POSTGRESQL__PASSWORD=CHANGEME

# =============================================================================
# REDIS
# =============================================================================
# Générer avec : openssl rand 24 | base64 -w 0
AUTHENTIK_REDIS__PASSWORD=CHANGEME

# =============================================================================
# COOKIE DOMAIN — Clé du SSO multi-sous-domaines
# =============================================================================
# Le point initial est OBLIGATOIRE pour couvrir tous les sous-domaines.
# Avec .yapserver.fr : un cookie posé sur auth.yapserver.fr est
# automatiquement transmis à nextcloud.yapserver.fr, jellyfin.yapserver.fr, etc.
# C'est ce mécanisme qui rend le SSO "transparent" (une seule authentification).
# =============================================================================
AUTHENTIK_COOKIE_DOMAIN=.yapserver.fr

# =============================================================================
# BOOTSTRAP — Compte administrateur initial
# =============================================================================
# Ces variables créent le premier compte admin AU PREMIER DÉMARRAGE UNIQUEMENT.
# Si le compte existe déjà, elles sont ignorées.
# BONNE PRATIQUE : Après le premier login réussi, commenter ou supprimer
# AUTHENTIK_BOOTSTRAP_PASSWORD de ce fichier.
# =============================================================================
AUTHENTIK_BOOTSTRAP_EMAIL=admin@yapserver.fr
AUTHENTIK_BOOTSTRAP_PASSWORD=CHANGEME

# =============================================================================
# EMAIL / SMTP (optionnel — recommandé pour les resets de MDP)
# =============================================================================
# Options gratuites pour homelab :
#   - Brevo (ex-Sendinblue) : 300 emails/jour gratuits
#   - Gmail SMTP : nécessite un "App Password" (pas le vrai MDP Google)
#   - Mailgun : 100 emails/jour gratuits
#
# Exemple Gmail :
#   HOST=smtp.gmail.com | PORT=587 | USE_TLS=true | USERNAME=votre@gmail.com
#   PASSWORD=votre_app_password (générer sur myaccount.google.com/apppasswords)
#
# Laisser localhost si vous ne voulez pas configurer l'email maintenant.
# Les fonctions de reset de MDP ne fonctionneront pas sans SMTP valide.
# =============================================================================
AUTHENTIK_EMAIL__HOST=localhost
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__USERNAME=
AUTHENTIK_EMAIL__PASSWORD=
AUTHENTIK_EMAIL__USE_TLS=false
AUTHENTIK_EMAIL__USE_SSL=false
AUTHENTIK_EMAIL__FROM=authentik@yapserver.fr

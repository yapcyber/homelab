# =============================================================================
# services/infra/homarr/.env.example
# =============================================================================

# Version — https://github.com/ajnart/homarr/releases
HOMARR_TAG=0.15.10

DOMAIN=yapserver.fr
TZ=Europe/Paris

# Clé secrète NextAuth — signature des cookies de session
# Générer avec : openssl rand 32 | base64 -w 0
HOMARR_NEXTAUTH_SECRET=CHANGEME

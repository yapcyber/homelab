# =============================================================================
# services/infra/netbox/.env.example
# Netbox — Documentation Infrastructure & IPAM
# =============================================================================

# Version — https://github.com/netbox-community/netbox/releases
# Format : vX.Y.Z (ex: v4.1.6)
NETBOX_TAG=v4.1.6

DOMAIN=yapserver.fr
TZ=Europe/Paris

# =============================================================================
# BASE DE DONNÉES POSTGRESQL
# =============================================================================
NETBOX_DB_NAME=netbox
NETBOX_DB_USER=netbox
# Générer : openssl rand 32 | base64 -w 0
NETBOX_DB_PASSWORD=CHANGEME

# =============================================================================
# REDIS
# =============================================================================
# Générer : openssl rand 24 | base64 -w 0
NETBOX_REDIS_PASSWORD=CHANGEME

# =============================================================================
# CLÉ SECRÈTE DJANGO — NE JAMAIS CHANGER APRÈS INITIALISATION
# =============================================================================
# Générer : python3 -c "import secrets; print(secrets.token_urlsafe(50))"
# Minimum 50 caractères requis par Django.
# Un changement invalide TOUTES les sessions et tokens API existants.
NETBOX_SECRET_KEY=CHANGEME

# =============================================================================
# COMPTE ADMINISTRATEUR INITIAL
# =============================================================================
# Créé automatiquement au premier démarrage si l'utilisateur n'existe pas.
# Changer le mot de passe depuis l'interface web après le premier login.
NETBOX_SUPERUSER_NAME=admin
NETBOX_SUPERUSER_EMAIL=admin@yapserver.fr
NETBOX_SUPERUSER_PASSWORD=CHANGEME

# Token API pour les intégrations (Ansible, scripts, webhooks)
# Générer : openssl rand 20 | xxd -p  (format hexadécimal, 40 chars)
# Ce token sera utilisé dès la Phase 4 pour l'intégration Ansible
NETBOX_SUPERUSER_API_TOKEN=CHANGEME

# =============================================================================
# QUOI DOCUMENTER EN PREMIER DANS NETBOX (Phase 4) ?
# =============================================================================
# 1. Sites & Locations : Ton rack physique
# 2. Device Types : Cisco 3560X, Mini PC 1, Lenovo Tiny...
# 3. Devices : chaque équipement physique avec numéro de série
# 4. IP Prefixes : les 10 VLANs (10.0.10.0/24, etc.)
# 5. IP Addresses : chaque IP assignée avec son équipement
# 6. VLANs : les 10 VLANs avec leur ID et description
# 7. Cables : câblage physique entre équipements
#
# Netbox deviendra la référence unique pour tout ce qui est infra —
# OPNsense, Proxmox, et Ansible s'y référeront pour la config automatisée.

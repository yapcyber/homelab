# =============================================================================
# services/infra/traefik/.env.example
# =============================================================================
# INSTRUCTIONS :
#   1. cp .env.example .env
#   2. Remplir TOUTES les valeurs marquées CHANGEME
#   3. Ne JAMAIS committer le fichier .env (présent dans .gitignore)
#   4. Pour partager : sops --encrypt .env > .enc.env (puis committer .enc.env)
# =============================================================================

# Domaine principal (utilisé dans les labels Traefik)
DOMAIN=yapserver.fr

# Timezone
TZ=Europe/Paris

# =============================================================================
# CLOUDFLARE — DNS Challenge Let's Encrypt + Tunnels
# =============================================================================
# Créer un token API Cloudflare sur :
#   https://dash.cloudflare.com/profile/api-tokens
#
# Permissions requises pour le token :
#   Zone > DNS > Edit       (pour créer les enregistrements TXT ACME)
#   Zone > Zone > Read      (pour lister les zones)
#   Scope : Zone spécifique yapserver.fr (principe du moindre privilège)
# =============================================================================
CF_API_EMAIL=CHANGEME@email.fr
CF_DNS_API_TOKEN=CHANGEME

# =============================================================================
# DASHBOARD TRAEFIK
# =============================================================================
# Le hash vit dans dynamic/secrets/traefik_users (gitignoré), pas dans .env.
# Générer le fichier :
#   Sur Ubuntu : sudo apt install apache2-utils
#   Commande   : htpasswd -nbB admin 'VOTRE_MOT_DE_PASSE' > dynamic/secrets/traefik_users
# =============================================================================

# =============================================================================
# CROWDSEC BOUNCER API KEY
# =============================================================================
# Cette clé est générée APRÈS le premier démarrage de CrowdSec.
# PROCÉDURE :
#   1. Lancer CrowdSec seul : docker compose up crowdsec -d
#   2. Attendre 30 secondes (initialisation)
#   3. Générer la clé : docker exec crowdsec cscli bouncers add traefik-bouncer
#   4. Copier la clé affichée ici
#   5. Relancer la stack complète : docker compose up -d
#
# La clé ressemble à : a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6
# =============================================================================
CROWDSEC_BOUNCER_API_KEY=CHANGEME

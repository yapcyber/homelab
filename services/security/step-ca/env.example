# =============================================================================
# services/security/step-ca/.env.example
# PKI interne — Step-CA (Smallstep)
# =============================================================================

# =============================================================================
# VERSION
# =============================================================================
# Vérifier la dernière version : https://github.com/smallstep/certificates/releases
# NE PAS utiliser "latest" — toujours pinner la version.
STEPCA_TAG=0.27.4

# =============================================================================
# IDENTITÉ DE L'AUTORITÉ DE CERTIFICATION
# =============================================================================
# Ces valeurs apparaissent dans TOUS les certificats émis (champ "Issuer").
# Elles sont définitives après la première initialisation.
# Les changer nécessite de recréer toute la PKI (et redistribuer le Root CA).

# Nom de la CA — apparaît dans les navigateurs quand ils font confiance à ce CA
CA_NAME=Yapserver Homelab CA

# DNS et IPs sur lesquels Step-CA est joignable
# Format : liste séparée par des virgules, SANS espaces
# Inclure : nom DNS interne (Split-DNS), IP VLAN Management, localhost
CA_DNS_NAMES=step-ca.int.yapserver.fr,step-ca,localhost,10.0.10.20

# Email de l'administrateur du provisioner initial
CA_ADMIN_EMAIL=admin@yapserver.fr

# =============================================================================
# MOT DE PASSE — Ne pas mettre ici, utiliser secrets/ca-password.txt
# =============================================================================
# Le mot de passe est lu depuis le FICHIER ./secrets/ca-password.txt
# et non depuis une variable d'environnement.
# Raison : les variables d'env Docker sont visibles via "docker inspect".
# Un fichier monté avec :ro est bien plus difficile à extraire.
#
# Le fichier est créé automatiquement par init.sh avec un mot de passe fort.
# Sauvegarder ce mot de passe dans un gestionnaire de mots de passe externe
# (Bitwarden, KeePass, etc.) — sans lui, impossible de redémarrer la CA.

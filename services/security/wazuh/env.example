# =============================================================================
# services/security/wazuh/.env.example
# Stack Wazuh SIEM
# =============================================================================

DOMAIN=yapserver.fr
TZ=Europe/Paris

# =============================================================================
# VERSION — https://github.com/wazuh/wazuh-docker/releases
# Toujours pinner — les migrations Wazuh peuvent être destructives.
# =============================================================================
WAZUH_VERSION=4.9.0

# =============================================================================
# MOTS DE PASSE
# =============================================================================
# Tous doivent être des chaînes robustes (min. 8 chars, maj+min+chiffres+symboles)
# Wazuh valide la complexité des mots de passe — trop simples = refusé.

# Mot de passe admin OpenSearch (Indexer)
# Utilisé par : Manager (Filebeat), Dashboard, scripts d'admin
# Générer : openssl rand -base64 24 | tr -d '+/=' | head -c 32
WAZUH_INDEXER_PASSWORD=CHANGEME

# Mot de passe du service Dashboard (communication Dashboard ↔ Indexer)
WAZUH_DASHBOARD_PASSWORD=CHANGEME

# Mot de passe de l'utilisateur API Wazuh (wazuh-wui)
# Utilisé par le Dashboard pour interroger l'API Manager
WAZUH_API_PASSWORD=CHANGEME

# =============================================================================
# JVM HEAP SIZE — Wazuh Indexer (OpenSearch)
# =============================================================================
# RÈGLE : 50% de la RAM disponible sur la VM, jamais > 31g.
#
# VM  8 Go RAM → WAZUH_INDEXER_JVM_HEAP=4g
# VM 16 Go RAM → WAZUH_INDEXER_JVM_HEAP=8g   ← Recommandé pour ce homelab
# VM 32 Go RAM → WAZUH_INDEXER_JVM_HEAP=16g  (si VM dédiée Wazuh uniquement)
#
# Trop bas → l'Indexer crashe avec OutOfMemoryError sur un grand volume de logs
# Trop haut → plus de RAM pour le Manager et le Dashboard → performances dégradées
WAZUH_INDEXER_JVM_HEAP=4g

# =============================================================================
# AGENTS — Installation sur chaque VM (Phase 4)
# =============================================================================
# Commande d'installation d'un agent Wazuh sur Debian/Ubuntu :
#
#   curl -s https://packages.wazuh.com/key/GPG-KEY-WAZUH | gpg --dearmor \
#     | sudo tee /usr/share/keyrings/wazuh.gpg > /dev/null
#   echo "deb [signed-by=/usr/share/keyrings/wazuh.gpg] \
#     https://packages.wazuh.com/4.x/apt/ stable main" \
#     | sudo tee /etc/apt/sources.list.d/wazuh.list
#   sudo apt-get update && sudo apt-get install wazuh-agent
#
#   sudo WAZUH_MANAGER="10.0.50.10" WAZUH_REGISTRATION_SERVER="10.0.50.10" \
#     systemctl enable --now wazuh-agent
#
# VMs à équiper (Phase 4) :
#   □ VM Traefik        (VLAN 40 - 10.0.40.10)
#   □ VM Authentik      (VLAN 30 - 10.0.30.10)
#   □ VM Nextcloud      (VLAN 30 - 10.0.30.30)
#   □ VM Immich         (VLAN 30 - 10.0.31.31)
#   □ VM Médias         (VLAN 30 - 10.0.30.20)
#   □ VM Homarr/Netbox  (VLAN 30 - 10.0.30.40)
#   □ VM Step-CA        (VLAN 10 - 10.0.10.20)
#   □ VM OpenVAS        (VLAN 50 - 10.0.50.20)
#   □ Jump Host         (VLAN 100 - 10.0.100.10)
# =============================================================================
